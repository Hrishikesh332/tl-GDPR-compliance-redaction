# TwelveLabs API key (required for indexing and search)
# Get it from https://playground.twelvelabs.io
TWELVELABS_API_KEY=your_twelvelabs_api_key_here

# TwelveLabs index ID (optional; has a default in config)
# Create an index in the TwelveLabs dashboard and paste its ID here
TWELVELABS_INDEX_ID=your_index_id_here

# Optional: entity collection for face entities (leave empty to auto-create)
# TWELVELABS_ENTITY_COLLECTION_ID=

# Optional: ping the hosted app URL on an interval to help keep it warm
SELF_APP_PING_URL=
SELF_APP_PING_INTERVAL_MINUTES=9
